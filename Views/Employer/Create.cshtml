@model JobPortalApp.Models.Job
@{
    ViewData["Title"] = "Đăng tin tuyển dụng";
    var categories = ViewBag.Categories as List<Category>;
}

<div class="container py-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3>@(ViewContext.RouteData.Values["Action"] == "Edit" ? "Sửa tin tuyển dụng" : "Đăng tin tuyển dụng mới")</h3>
        </div>
        <div class="card-body">
            <form asp-action="@(ViewContext.RouteData.Values["Action"])" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label">Tiêu đề tin</label>
                            <input asp-for="Title" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mô tả công việc</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Yêu cầu ứng viên</label>
                            <textarea asp-for="Requirements" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Ngành nghề</label>
                            <select asp-for="CategoryId" class="form-select">
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Lương từ</label>
                            <input asp-for="SalaryFrom" type="number" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Lương đến</label>
                            <input asp-for="SalaryTo" type="number" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Địa điểm</label>
                            <input asp-for="Location" class="form-control" />
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-success btn-lg w-100">Lưu tin tuyển dụng</button>
            </form>
        </div>
    </div>
</div>
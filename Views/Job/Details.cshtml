@model JobPortalApp.Models.Job
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">
    <div class="row">
        <!-- Thông tin chi tiết -->
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h1 class="h2 fw-bold">@Model.Title</h1>
                    <p class="text-muted mb-0">
                        <i class="fas fa-building"></i> @Model.Employer?.FullName
                    </p>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <strong>Lương:</strong><br>
                            <span class="text-success fs-4 fw-bold">
                                @if (Model.SalaryFrom.HasValue && Model.SalaryTo.HasValue)
                                {
                                    @($"{Model.SalaryFrom.Value:0,0} - {Model.SalaryTo.Value:0,0} VNĐ")
                                }
                                else
                                {

                                    <span>Thương lượng</span>
                                }
                            </span>
                        </div>
                        <div class="col-md-4">
                            <strong>Địa điểm:</strong><br>
                            <span class="fs-5">@Model.Location</span>
                        </div>
                        <div class="col-md-4">
                            <strong>Hình thức:</strong><br>
                            <span class="badge bg-primary">@Model.JobType</span>
                        </div>
                    </div>

                    <h5 class="fw-bold">Mô tả công việc</h5>
                    <p class="lead">@Model.Description</p>

                    <h5 class="fw-bold mt-4">Yêu cầu ứng viên</h5>
                    <p>@Model.Requirements</p>

                    <h5 class="fw-bold mt-4">Kinh nghiệm</h5>
                    <p>@Model.Experience năm kinh nghiệm</p>

                    <h5 class="fw-bold mt-4">Ngành nghề</h5>
                    <p><span class="badge bg-info">@Model.Category?.Name</span></p>

                    <div class="mt-4">
                        <small class="text-muted">
                            Ngày đăng: @Model.PostedDate.ToString("dd/MM/yyyy")
                            | Hạn nộp: @Model.ExpiryDate?.ToString("dd/MM/yyyy")
                        </small>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <a href="#" class="btn btn-success btn-lg w-100"
                           onclick="alert('Tính năng nộp đơn sẽ được làm ở bước sau!')">
                        <i class="fas fa-paper-plane"></i> Nộp đơn ứng tuyển ngay
                    </a>
                    @if (User.IsInRole("Seeker"))
                    {
                        <a asp-controller="Application" asp-action="Apply" asp-route-jobId="@Model.Id"
                               class="btn btn-success btn-lg w-100">
                            <i class="fas fa-paper-plane"></i> Nộp đơn ứng tuyển
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar thông tin công ty -->
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="fw-bold">Thông tin nhà tuyển dụng</h5>
                    <hr>
                    <p><strong>@Model.Employer?.FullName</strong></p>
                    <p class="text-muted">@Model.Employer?.Phone</p>
                    <a href="#" class="btn btn-outline-primary w-100">Xem trang công ty</a>
                </div>
            </div>
        </div>
    </div>
</div>
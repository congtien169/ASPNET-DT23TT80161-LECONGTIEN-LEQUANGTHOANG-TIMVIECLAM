<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobPortal</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" asp-controller="Home" asp-action="Index">JobPortal</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Job" asp-action="Search">Tìm việc</a></li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 text-light" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle fa-2x"></i>
                                Xin chào, <strong>@User.Identity.Name</strong>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                @if (User.IsInRole("Seeker"))
                                {
                                    <li><a class="dropdown-item" asp-controller="Seeker" asp-action="CompleteProfile">Hồ sơ CV</a></li>
                                }
                                else if (User.IsInRole("Employer"))
                                {
                                    <li><a class="dropdown-item" asp-controller="Employer" asp-action="Index">Quản lý tin</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-3">
                            <a class="btn btn-light fw-semibold px-4" asp-controller="Account" asp-action="Register">Đăng ký</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light fw-semibold px-4" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- NỘI DUNG CHÍNH -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- FOOTER ĐẸP -->
    <footer class="bg-dark text-light py-5 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="fw-bold">JobPortal</h5>
                    <p class="text-muted small">Kết nối cơ hội việc làm - Kết nối tương lai</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0 small">
                        © 2026 JobPortalApp. All rights reserved.<br>
                        <a href="#" class="text-light text-decoration-underline">Privacy</a> |
                        <a href="#" class="text-light text-decoration-underline">Điều khoản</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>